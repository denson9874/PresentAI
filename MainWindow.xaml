<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PresentAI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PresentAI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PresentAI"
    mc:Ignorable="d">
    <Grid x:Name="RootGrid" Background="#F5F2EA" KeyDown="RootGrid_OnKeyDown" IsTabStop="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#18201E" Padding="22">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="PresentAI" Foreground="#F7F1DF" FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="AI deck builder and speaker console" Foreground="#AFC5BC" Margin="0,0,0,14" />

                    <TextBlock Text="Provider" Foreground="#F7F1DF" />
                    <ComboBox x:Name="ProviderBox" SelectionChanged="ProviderBox_OnSelectionChanged">
                        <ComboBoxItem Content="OpenAI" IsSelected="True" />
                        <ComboBoxItem Content="Gemini" />
                    </ComboBox>

                    <TextBlock Text="API Key" Foreground="#F7F1DF" />
                    <PasswordBox x:Name="ApiKeyBox" />

                    <TextBlock Text="Model" Foreground="#F7F1DF" />
                    <TextBox x:Name="ModelBox" Text="gpt-4.1-mini" />

                    <TextBlock Text="Slide Count" Foreground="#F7F1DF" />
                    <Slider x:Name="SlideCountSlider" Minimum="4" Maximum="14" Value="8" StepFrequency="1" />
                    <TextBlock x:Name="SlideCountText" Text="8 slides" Foreground="#AFC5BC" />

                    <TextBlock Text="Suggested Prompt" Foreground="#F7F1DF" Margin="0,8,0,0" />
                    <TextBox x:Name="PromptBox" MinHeight="150" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Text="Create a persuasive investor presentation for an AI-powered desktop tool that turns rough ideas into polished slide decks with speaker notes." />

                    <Button x:Name="GenerateButton" Content="Generate Deck" Click="GenerateButton_OnClick" Background="#2F7D79" Foreground="White" Margin="0,10,0,0" />
                    <TextBlock x:Name="StatusText" Text="Ready" Foreground="#AFC5BC" TextWrapping="Wrap" Margin="0,4,0,14" />

                    <TextBlock Text="Display" Foreground="#F7F1DF" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <ComboBox x:Name="DisplayBox" DisplayMemberPath="Label" />
                    <Button Content="Open Presentation View" Click="OpenPresentationButton_OnClick" Background="#D0A24B" Foreground="#101218" />
                    <Button Content="Full Screen / Restore" Click="ToggleFullScreenButton_OnClick" Background="#E7E0CE" Foreground="#101218" />

                    <TextBlock Text="AirPlay / Google Cast" Foreground="#F7F1DF" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,0" />
                    <TextBox x:Name="ReceiverUrlBox" IsReadOnly="True" />
                    <Button Content="Open Receiver URL" Click="OpenReceiverButton_OnClick" Background="#E7E0CE" Foreground="#101218" />
                    <Button Content="Open Chrome/Edge Cast Window" Click="OpenCastButton_OnClick" Background="#E7E0CE" Foreground="#101218" />
                    <TextBlock Text="Use the receiver URL with browser tab casting, Google Cast, AirPlay mirroring, or a display-connected browser." Foreground="#AFC5BC" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="DeckTitleText" Text="No deck yet" Foreground="#101218" FontSize="28" FontWeight="Bold" />
                    <TextBlock x:Name="DeckSubtitleText" Text="Generate a deck or use local draft mode by leaving the API key blank." Foreground="#53625D" TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock x:Name="CounterText" Grid.Column="1" Text="0 / 0" Foreground="#53625D" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="1" Background="#101218" CornerRadius="8" Padding="42" Margin="0,20,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="SlideTitleText" Text="Presentation preview" Foreground="#F7F1DF" FontSize="46" FontWeight="Bold" TextWrapping="Wrap" />
                    <ItemsControl x:Name="BulletList" Grid.Row="1" Margin="0,34,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#F7F1DF" FontSize="27" TextWrapping="Wrap" Margin="0,0,0,18" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="VisualHintText" Grid.Row="2" Foreground="#9FB7AD" FontSize="16" TextWrapping="Wrap" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                <Button Content="Previous" Click="PreviousButton_OnClick" Background="#E7E0CE" />
                <Button Content="Next" Click="NextButton_OnClick" Background="#2F7D79" Foreground="White" />
                <Button x:Name="TimerButton" Content="Start Timer" Click="TimerButton_OnClick" Background="#E7E0CE" />
                <TextBlock x:Name="TimerText" Text="00:00" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Margin="12,0,0,0" />
            </StackPanel>
        </Grid>

        <Border Grid.Column="2" Background="#E7E0CE" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Speaker Notes" Foreground="#101218" FontSize="22" FontWeight="Bold" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,18">
                    <TextBlock x:Name="NotesText" Text="Notes will appear here for each generated slide." Foreground="#1C2522" FontSize="18" TextWrapping="Wrap" LineHeight="28" />
                </ScrollViewer>

                <StackPanel Grid.Row="2" Spacing="8">
                    <TextBlock Text="Next Slide" Foreground="#53625D" FontWeight="SemiBold" />
                    <TextBlock x:Name="NextSlideText" Text="-" Foreground="#101218" FontSize="18" TextWrapping="Wrap" Margin="0,0,0,10" />
                    <Button Content="Export Markdown" Click="ExportMarkdownButton_OnClick" Background="#18201E" Foreground="White" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
