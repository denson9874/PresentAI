<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PresentAI.PresentationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PresentAI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PresentAI Presentation"
    mc:Ignorable="d">
    <Grid x:Name="RootGrid" Background="#101218" KeyDown="RootGrid_OnKeyDown" IsTabStop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Margin="80">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="SlideTitleText" Text="Ready" Foreground="#F7F1DF" FontSize="72" FontWeight="Bold" TextWrapping="Wrap" LineHeight="78" />
            <ItemsControl x:Name="BulletList" Grid.Row="1" Margin="0,56,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#F7F1DF" FontSize="38" TextWrapping="Wrap" Margin="0,0,0,28" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        <Grid Grid.Row="1" Margin="34,0,34,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="DeckText" Foreground="#9FB7AD" FontSize="18" />
            <TextBlock x:Name="CounterText" Grid.Column="1" Foreground="#9FB7AD" FontSize="18" />
        </Grid>
    </Grid>
</Window>
